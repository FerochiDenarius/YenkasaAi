APP_NAME=YenkasaAI Cloud Backend
APP_ENV=production
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8080
CORS_ALLOW_ORIGINS=https://your-frontend.example

VERTEX_AI_PROJECT_ID=project-10405180-0afd-4ecc-9f8
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-2.5-flash
VERTEX_AI_TEMPERATURE=0.2
GEMINI_REASONING_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-005

GCS_BUCKET=your-gcs-bucket
GCS_CHROMA_PREFIX=yenkasa-ai/chroma
GCS_KNOWLEDGE_PREFIX=yenkasa-ai/knowledge
CHROMA_COLLECTION_NAME=yenkasa_research
CHROMA_PUBLIC_COLLECTION_NAME=yenkasa_platform_knowledge
PUBLIC_KNOWLEDGE_BOOTSTRAP_DIR=/workspace/knowledge/semantic/public

DEV_INTELLIGENCE_ENABLED=true
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=yenkasa_ai_db
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_CHUNKS_COLLECTION=ai_embeddings
MONGODB_JOBS_COLLECTION=ai_jobs
MONGODB_INSIGHTS_COLLECTION=ai_metrics
MONGODB_EVENTS_COLLECTION=ai_usage
MONGODB_USERS_COLLECTION=ai_users
MONGODB_SESSIONS_COLLECTION=ai_sessions
MONGODB_YME_COLLECTION=ai_memory
MONGODB_YME_MEMORIES_COLLECTION=yme_memories
MONGODB_YME_GRAPH_COLLECTION=yme_graph
MONGODB_CONVERSATIONS_COLLECTION=ai_chats
MONGODB_SECURITY_ALERTS_COLLECTION=moderation_logs
MONGODB_LOGS_COLLECTION=ai_logs
MONGODB_LOG_ALERTS_COLLECTION=ai_log_alerts
MONGODB_GITHUB_REPOSITORIES_COLLECTION=github_repositories
MONGODB_REPO_ARCHITECTURE_COLLECTION=repo_architecture
MONGODB_VECTOR_INDEX_NAME=repo_chunks_vector_index
MONGODB_VECTOR_DIMENSIONS=768
MONGODB_YME_VECTOR_INDEX_NAME=yme_memories_vector_index
MONGODB_YME_VECTOR_DIMENSIONS=768

REDIS_URL=redis://your-redis-host:6379/0
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REPO_INGESTION_QUEUE_NAME=repo-ingestion
REPO_INGESTION_JOB_TIMEOUT_S=3600
GITHUB_SYNC_QUEUE_NAME=github-sync
GITHUB_SYNC_JOB_TIMEOUT_S=7200
REPO_ALLOWED_ROOTS=/workspace,/tmp
REPO_CHUNK_MAX_LINES=90
REPO_CHUNK_OVERLAP_LINES=15
REPO_FILE_SIZE_LIMIT_BYTES=1048576
REPO_INSIGHT_LARGE_FILE_LINES=1200
REPO_SEARCH_TOP_K=6
REPO_SEARCH_NUM_CANDIDATES=120
GITHUB_TOKEN=ghp_replace_me
GITHUB_OWNER=FerochiDenarius
GITHUB_SCAN_ALL_REPOS=true
GITHUB_REPO_CACHE_ROOT=/tmp/yenkasa-ai/repo_cache
GITHUB_CLONE_DEPTH=1
GITHUB_SCAN_MAX_FILES=4000
EMBEDDING_BATCH_SIZE=12
EMBEDDING_RETRY_ATTEMPTS=3
INTERNAL_PLATFORM_API_KEY=replace-with-shared-internal-key
INTERNAL_PLATFORM_BATCH_RATE_LIMIT=240
INTERNAL_PLATFORM_HEALTH_RATE_LIMIT=60

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=1440
REFRESH_TOKEN_TTL_DAYS=30
AUTH_WINDOW_SECONDS=900
AUTH_LOGIN_RATE_LIMIT=12
AUTH_REGISTER_RATE_LIMIT=5
AI_REQUEST_RATE_LIMIT=120
MAX_CONCURRENT_SESSIONS=5
YME_ENABLED=true
YME_EMBEDDING_ENABLED=true
YME_MIN_IMPORTANCE_SCORE=0.18
YME_MEMORY_SEARCH_LIMIT=8
YME_MEMORY_INJECTION_LIMIT=5
YME_MEMORY_CONTEXT_CHAR_BUDGET=2400
YME_MEMORY_CLEANUP_DAYS=45
DEPLOY_GENERATION=20260525-000000
