APP_NAME=YenkasaAI Cloud Backend
APP_ENV=production
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8080
CORS_ALLOW_ORIGINS=https://your-frontend.example

VERTEX_AI_PROJECT_ID=project-10405180-0afd-4ecc-9f8
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-2.5-flash
VERTEX_AI_TEMPERATURE=0.2
GEMINI_REASONING_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-005

GCS_BUCKET=your-gcs-bucket
GCS_CHROMA_PREFIX=yenkasa-ai/chroma
GCS_KNOWLEDGE_PREFIX=yenkasa-ai/knowledge
CHROMA_COLLECTION_NAME=yenkasa_research
CHROMA_PUBLIC_COLLECTION_NAME=yenkasa_platform_knowledge
PUBLIC_KNOWLEDGE_BOOTSTRAP_DIR=/workspace/knowledge/semantic/public

DEV_INTELLIGENCE_ENABLED=true
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=yenkasa_ai
MONGODB_VECTOR_INDEX_NAME=repo_chunks_vector_index
MONGODB_VECTOR_DIMENSIONS=768

REDIS_URL=redis://your-redis-host:6379/0
REPO_INGESTION_QUEUE_NAME=repo-ingestion
REPO_INGESTION_JOB_TIMEOUT_S=3600
REPO_ALLOWED_ROOTS=/workspace,/tmp
REPO_CHUNK_MAX_LINES=90
REPO_CHUNK_OVERLAP_LINES=15
REPO_FILE_SIZE_LIMIT_BYTES=1048576
REPO_INSIGHT_LARGE_FILE_LINES=1200
REPO_SEARCH_TOP_K=6
REPO_SEARCH_NUM_CANDIDATES=120
EMBEDDING_BATCH_SIZE=12
EMBEDDING_RETRY_ATTEMPTS=3

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=30
AUTH_WINDOW_SECONDS=900
AUTH_LOGIN_RATE_LIMIT=12
AUTH_REGISTER_RATE_LIMIT=5
AI_REQUEST_RATE_LIMIT=120
MAX_CONCURRENT_SESSIONS=5
